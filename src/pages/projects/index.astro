---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Proyectos" description="Cosas que estoy construyendo y experimentando.">
  <h1 class="text-3xl font-semibold tracking-tight mb-2">Proyectos</h1>
  <p class="text-(--color-text-secondary) mb-10">Cosas que estoy construyendo y experimentando.</p>

  <div class="flex flex-col items-center justify-center py-20 text-center">
    <span class="text-4xl mb-4">🚧</span>
    <p class="text-lg text-(--color-text-secondary)">Próximamente...</p>
  </div>
</BaseLayout>
