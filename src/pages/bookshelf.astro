---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getBooks, type Book } from '../lib/goodreads';

const { reading, read, toRead } = await getBooks();

function renderStars(rating: number): string {
  if (rating === 0) return '';
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}

const INITIAL_COUNT = 4;
const YEARLY_GOAL = 15;
const currentYear = new Date().getFullYear();
const booksReadThisYear = read.filter(b => {
  if (!b.readAt) return false;
  const readDate = new Date(b.readAt);
  return readDate.getFullYear() === currentYear;
}).length;
const goalPercent = Math.min(Math.round((booksReadThisYear / YEARLY_GOAL) * 100), 100);

const currentlyReading = reading.length > 0 ? reading[0] : null;

const alquimista = read.find(b => b.title.toLowerCase().includes('alquimista'));
const favouriteBook = {
  title: 'El Alquimista',
  author: 'Paulo Coelho',
  cover: alquimista?.cover ?? '',
  link: alquimista?.link ?? 'https://www.goodreads.com/book/show/45497',
};

const shelves: { id: string; label: string; books: Book[] }[] = [
  { id: 'reading', label: 'Leyendo ahora', books: reading },
  { id: 'read', label: 'Leídos', books: read },
  { id: 'toread', label: 'Quiero leer', books: toRead },
];
---

<BaseLayout title="Lecturas" description="Libros que estoy leyendo y que leí.">
  <h1 class="text-3xl font-semibold tracking-tight mb-2">Lecturas</h1>
  <p class="text-(--color-text-secondary) mb-2">Lo que estoy leyendo, lo que leí y lo que quiero leer.</p>
  <p class="text-xs text-(--color-text-secondary) mb-8">
    Sincronizado con <a href="https://www.goodreads.com/user/show/198954569-jos-lagos" target="_blank" rel="noopener" class="text-(--color-accent) hover:underline">mi Goodreads</a>
  </p>

  <!-- KPI Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
    <!-- Books read this year -->
    <a href="https://www.goodreads.com/user_challenges/198954569" target="_blank" rel="noopener" class="block rounded-xl border border-(--color-border) p-5 bg-(--color-surface) no-underline transition-all duration-200 hover:border-(--color-accent) hover:bg-(--color-surface)/80 hover:scale-[1.02]">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-lg">📚</span>
        <span class="text-xs font-medium uppercase tracking-wider text-(--color-text-secondary)">Meta 2026</span>
      </div>
      <div class="flex items-baseline gap-2 mb-3">
        <span class="text-3xl font-bold">{booksReadThisYear}</span>
        <span class="text-sm text-(--color-text-secondary)">/ {YEARLY_GOAL} libros</span>
      </div>
      <div class="w-full h-2 rounded-full bg-(--color-border) overflow-hidden">
        <div class="h-full rounded-full bg-(--color-accent) transition-all duration-500" style={`width: ${goalPercent}%`}></div>
      </div>
      <span class="text-xs text-(--color-text-secondary) mt-2 block">{goalPercent}% completado</span>
    </a>

    <!-- Currently reading -->
    <a href={currentlyReading?.link ?? '#'} target="_blank" rel="noopener" class="block rounded-xl border border-(--color-border) p-5 bg-(--color-surface) no-underline transition-all duration-200 hover:border-(--color-accent) hover:bg-(--color-surface)/80 hover:scale-[1.02]">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-lg">📖</span>
        <span class="text-xs font-medium uppercase tracking-wider text-(--color-text-secondary)">Leyendo ahora</span>
      </div>
      {currentlyReading ? (
        <div class="flex items-center gap-3">
          {currentlyReading.cover && (
            <img src={currentlyReading.cover} alt={currentlyReading.title} class="w-10 h-14 object-cover rounded shadow-sm" />
          )}
          <div class="min-w-0">
            <p class="font-medium text-sm leading-tight truncate">{currentlyReading.title}</p>
            <p class="text-xs text-(--color-text-secondary) mt-0.5 truncate">{currentlyReading.author}</p>
          </div>
        </div>
      ) : (
        <p class="text-sm text-(--color-text-secondary)">Nada por ahora</p>
      )}
    </a>

    <!-- Favourite book -->
    <a href={favouriteBook.link} target="_blank" rel="noopener" class="block rounded-xl border border-(--color-border) p-5 bg-(--color-surface) no-underline transition-all duration-200 hover:border-(--color-accent) hover:bg-(--color-surface)/80 hover:scale-[1.02]">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-lg">⭐</span>
        <span class="text-xs font-medium uppercase tracking-wider text-(--color-text-secondary)">Mi favorito</span>
      </div>
      <div class="flex items-center gap-3">
        {favouriteBook.cover && (
          <img src={favouriteBook.cover} alt={favouriteBook.title} class="w-10 h-14 object-cover rounded shadow-sm" />
        )}
        <div class="min-w-0">
          <p class="font-medium text-sm leading-tight">{favouriteBook.title}</p>
          <p class="text-xs text-(--color-text-secondary) mt-0.5">{favouriteBook.author}</p>
        </div>
      </div>
    </a>
  </div>

  {shelves.map(shelf => shelf.books.length > 0 && (
    <section class="mb-12">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-lg font-semibold">{shelf.label}</h2>
        <span class="text-xs text-(--color-text-secondary)">{shelf.books.length} libros</span>
      </div>
      <ul class="grid grid-cols-1 gap-6" id={`shelf-${shelf.id}`}>
        {shelf.books.map((book, i) => (
          <li class:list={[i >= INITIAL_COUNT && 'hidden', 'shelf-item']}>
            <div class="flex gap-4 items-start">
              {book.cover && (
                <a href={book.link} target="_blank" rel="noopener" class="shrink-0">
                  <img
                    src={book.cover}
                    alt={book.title}
                    class="w-16 h-24 object-cover rounded shadow-sm hover:opacity-80 transition-opacity"
                    loading="lazy"
                  />
                </a>
              )}
              <div class="min-w-0">
                <a href={book.link} target="_blank" rel="noopener" class="font-medium hover:text-(--color-accent) transition-colors block">{book.title}</a>
                <span class="text-sm text-(--color-text-secondary) block mt-0.5">{book.author}</span>
                <div class="flex items-center gap-3 mt-1 text-xs text-(--color-text-secondary)">
                  {book.rating > 0 && (
                    <span class="text-amber-500">{renderStars(book.rating)}</span>
                  )}
                  {book.pages > 0 && <span>{book.pages} págs.</span>}
                </div>
                {book.review && (
                  <a
                    href={book.link}
                    target="_blank"
                    rel="noopener"
                    class="inline-block mt-2 text-xs text-(--color-accent) hover:underline"
                  >
                    Leer mi reseña &rarr;
                  </a>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
      {shelf.books.length > INITIAL_COUNT && (
        <button
          class="mt-4 text-sm text-(--color-accent) hover:underline cursor-pointer shelf-toggle"
          data-shelf={shelf.id}
          data-total={shelf.books.length}
        >
          Ver más ({shelf.books.length - INITIAL_COUNT} restantes)
        </button>
      )}
    </section>
  ))}
</BaseLayout>

<script is:inline>
  document.querySelectorAll('.shelf-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var shelfId = btn.getAttribute('data-shelf');
      var shelf = document.getElementById('shelf-' + shelfId);
      var items = shelf.querySelectorAll('.shelf-item.hidden');
      if (items.length > 0) {
        items.forEach(function(item) { item.classList.remove('hidden'); });
        btn.textContent = 'Ver menos';
        btn.dataset.expanded = 'true';
      } else {
        var allItems = shelf.querySelectorAll('.shelf-item');
        allItems.forEach(function(item, i) {
          if (i >= 4) item.classList.add('hidden');
        });
        var total = Number(btn.getAttribute('data-total'));
        btn.textContent = 'Ver más (' + (total - 4) + ' restantes)';
        btn.dataset.expanded = 'false';
      }
    });
  });
</script>
