---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="Ideas, pensamientos y cosas que voy aprendiendo.">
  <h1 class="text-3xl font-semibold tracking-tight mb-2">Blog</h1>
  <p class="text-(--color-text-secondary) mb-10">Ideas, pensamientos y cosas que voy aprendiendo.</p>

  {posts.length > 0 ? (
    <ul class="flex flex-col gap-6">
      {posts.map(post => (
        <li>
          <a href={`/blog/${post.id}`} class="group block rounded-xl border border-(--color-border) bg-(--color-bg-secondary) overflow-hidden transition-all hover:border-(--color-accent)/40 hover:shadow-lg">
            <div class="flex flex-col sm:flex-row">
              <div class="sm:w-56 sm:h-auto h-48 shrink-0 overflow-hidden">
                <img
                  src={post.data.banner}
                  alt={post.data.title}
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
              <div class="flex-1 p-5 flex flex-col justify-center">
                <div class="flex items-baseline justify-between gap-4 mb-1">
                  <h2 class="font-semibold text-lg group-hover:text-(--color-accent) transition-colors">{post.data.title}</h2>
                  <span class="text-sm text-(--color-text-secondary) shrink-0">
                    {post.data.date.toLocaleDateString('es-AR', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
                <p class="text-sm text-(--color-text-secondary) mb-3">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="flex gap-2">
                    {post.data.tags.map(tag => (
                      <span class="text-xs px-2 py-0.5 bg-(--color-bg) rounded-full text-(--color-text-secondary)">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="text-(--color-text-secondary)">No hay posts todavía. ¡Volvé pronto!</p>
  )}
</BaseLayout>
