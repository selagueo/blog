---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About José Lagos.">
  <h1 class="text-3xl font-semibold tracking-tight mb-4">About</h1>

  <div class="prose">
    <p>
      Hey, I'm José Lagos. Developer, maker, and occasional writer.
    </p>

    <p>
      I like building things for the web, reading, and discovering new music. This site is my personal space to share what I'm working on and thinking about.
    </p>

    <p>
      You can find me on <a href="https://instagram.com/selagueo" target="_blank" rel="noopener">Instagram</a> and <a href="https://github.com/selagueo" target="_blank" rel="noopener">GitHub</a> as <strong>@selagueo</strong>.
    </p>

    <h2>Get in touch</h2>
    <p>
      Feel free to reach out — DM me on Instagram or find me on GitHub.
    </p>
  </div>
</BaseLayout>
