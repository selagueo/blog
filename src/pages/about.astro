---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sobre mí" description="Sobre José Lagos.">
  <!-- Hero -->
  <section class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-14 hero-fade hero-fade-delay-1">
    <img
      src="/images/profile.jpg"
      alt="José Lagos"
      class="w-48 h-48 sm:w-56 sm:h-56 rounded-full object-cover ring-2 ring-(--color-border) shrink-0"
    />
    <div class="text-center sm:text-left flex flex-col justify-center">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-2">José Lagos Guevara</h1>
      <p class="text-lg text-(--color-text-secondary) mb-5">Emprendedor, desarrollador, golfista, product designer, ingeniero y artista <span class="italic">(entre otras mentiras)</span>.</p>
      <div class="flex flex-wrap justify-center sm:justify-start gap-3">
        <a href="https://instagram.com/selagueo" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-(--color-border) bg-(--color-bg-secondary) text-sm text-(--color-text-secondary) hover:text-(--color-accent) hover:border-(--color-accent)/40 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          Instagram
        </a>
        <a href="https://github.com/selagueo" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-(--color-border) bg-(--color-bg-secondary) text-sm text-(--color-text-secondary) hover:text-(--color-accent) hover:border-(--color-accent)/40 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://linkedin.com/in/selagueo" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-(--color-border) bg-(--color-bg-secondary) text-sm text-(--color-text-secondary) hover:text-(--color-accent) hover:border-(--color-accent)/40 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="w-12 h-0.5 bg-(--color-accent) mb-12 hero-fade hero-fade-delay-2"></div>

  <!-- Sobre mí -->
  <section class="mb-12 hero-fade hero-fade-delay-2">
    <h2 class="text-xl font-semibold tracking-tight mb-4 pl-4 border-l-2 border-(--color-accent)">Sobre mí</h2>
    <div class="text-(--color-text-secondary) leading-relaxed space-y-4 max-w-2xl">
      <p>Hola, soy José Lagos. Desarrollador, maker y escritor ocasional.</p>
      <p>Me gusta construir cosas para la web, leer y descubrir música nueva. Este sitio es mi espacio personal para compartir lo que estoy haciendo y pensando.</p>
    </div>
  </section>

  <!-- Qué hago -->
  <section class="mb-12 hero-fade hero-fade-delay-3">
    <h2 class="text-xl font-semibold tracking-tight mb-4 pl-4 border-l-2 border-(--color-accent)">Qué hago</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-(--color-border) bg-(--color-bg-secondary)">
        <span class="text-xl">💻</span>
        <span class="text-sm font-medium">Desarrollo</span>
      </div>
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-(--color-border) bg-(--color-bg-secondary)">
        <span class="text-xl">🎨</span>
        <span class="text-sm font-medium">Product Design</span>
      </div>
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-(--color-border) bg-(--color-bg-secondary)">
        <span class="text-xl">🧠</span>
        <span class="text-sm font-medium">UX</span>
      </div>
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-(--color-border) bg-(--color-bg-secondary)">
        <span class="text-xl">⛳</span>
        <span class="text-sm font-medium">Golf</span>
      </div>
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-(--color-border) bg-(--color-bg-secondary)">
        <span class="text-xl">📚</span>
        <span class="text-sm font-medium">Lectura</span>
      </div>
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-(--color-border) bg-(--color-bg-secondary)">
        <span class="text-xl">🎵</span>
        <span class="text-sm font-medium">Música</span>
      </div>
    </div>
  </section>

  <!-- Contacto -->
  <section class="hero-fade hero-fade-delay-3">
    <h2 class="text-xl font-semibold tracking-tight mb-4 pl-4 border-l-2 border-(--color-accent)">Contacto</h2>
    <p class="text-(--color-text-secondary) leading-relaxed max-w-2xl">
      Escribime tranquilo — por DM en <a href="https://instagram.com/selagueo" target="_blank" rel="noopener" class="text-(--color-accent) hover:underline underline-offset-2">Instagram</a> o por <a href="https://github.com/selagueo" target="_blank" rel="noopener" class="text-(--color-accent) hover:underline underline-offset-2">GitHub</a>.
    </p>
  </section>
</BaseLayout>
