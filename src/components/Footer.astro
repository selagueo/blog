---
const year = new Date().getFullYear();
---

<footer class="w-full max-w-5xl mx-auto px-6 py-8 border-t border-(--color-border)">
  <div class="flex flex-col gap-6 text-sm text-(--color-text-secondary)">
    <!-- Newsletter -->
    <div class="flex flex-col sm:flex-row sm:items-end gap-4 pb-2">
      <div class="flex-1">
        <h3 class="text-base font-semibold text-(--color-text) mb-1">Suscribite al newsletter</h3>
        <p class="text-xs">Recibí un email cuando publique algo nuevo.</p>
      </div>
      <form id="newsletter-form" class="flex flex-col gap-2 w-full sm:w-auto">
        <div class="flex gap-2">
          <input
            id="newsletter-email"
            type="email"
            placeholder="tu@email.com"
            required
            class="flex-1 sm:w-56 px-3 py-2 rounded-lg border border-(--color-border) bg-(--color-bg) text-sm text-(--color-text) placeholder:text-(--color-text-secondary) focus:outline-none focus:border-(--color-accent) transition-colors"
          />
          <button
            type="submit"
            id="newsletter-btn"
            class="px-4 py-2 rounded-lg bg-(--color-accent) text-sm font-medium text-white hover:opacity-90 transition-opacity cursor-pointer shrink-0 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Suscribirme
          </button>
        </div>
        <div class="cf-turnstile" data-sitekey="0x4AAAAAACq8h8jd0CWb6lSD" data-theme="dark" data-size="compact"></div>
      </form>
    </div>
    <p id="newsletter-msg" class="hidden text-xs -mt-4"></p>

    <!-- Top row: controls + social -->
    <div class="flex items-center justify-between">
      <button
        id="theme-toggle-footer"
        aria-label="Cambiar tema"
        class="hover:text-(--color-text) transition-colors cursor-pointer text-base"
      >
        <span id="ft-icon-light" class="hidden">☀</span>
        <span id="ft-icon-dark" class="hidden">☾</span>
      </button>
      <div class="flex gap-4">
        <a href="https://instagram.com/selagueo" target="_blank" rel="noopener" class="hover:text-(--color-text) transition-colors">Instagram</a>
        <a href="https://github.com/selagueo" target="_blank" rel="noopener" class="hover:text-(--color-text) transition-colors">GitHub</a>
      </div>
    </div>
    <!-- Bottom row: copyright + powered by -->
    <div class="flex items-center justify-between">
      <span>&copy; {year} José Lagos</span>
      <span>Powered by <a href="https://lajo.ar" target="_blank" rel="noopener" class="hover:text-(--color-text) transition-colors underline underline-offset-2">lajo.ar</a></span>
    </div>
  </div>
</footer>

<script is:inline>
  (function() {
    var toggle = document.getElementById('theme-toggle-footer');
    var iconLight = document.getElementById('ft-icon-light');
    var iconDark = document.getElementById('ft-icon-dark');

    function updateIcon() {
      var isDark = document.documentElement.classList.contains('dark');
      iconLight.classList.toggle('hidden', !isDark);
      iconDark.classList.toggle('hidden', isDark);
    }

    updateIcon();

    toggle.addEventListener('click', function() {
      var isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcon();
    });
  })();

  // Newsletter form
  var form = document.getElementById('newsletter-form');
  var emailInput = document.getElementById('newsletter-email');
  var btn = document.getElementById('newsletter-btn');
  var msg = document.getElementById('newsletter-msg');

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var email = emailInput.value.trim();
    if (!email) return;

    var turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
    var turnstileToken = turnstileInput ? turnstileInput.value : '';
    if (!turnstileToken) {
      msg.classList.remove('hidden');
      msg.textContent = 'Esperá a que se complete la verificación de seguridad.';
      msg.style.color = '#FF9A2E';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Enviando...';
    msg.classList.add('hidden');

    fetch('/api/newsletter/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, turnstileToken: turnstileToken })
    })
    .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
    .then(function(result) {
      msg.classList.remove('hidden');
      if (result.ok) {
        msg.textContent = '¡Te suscribiste! Revisá tu email.';
        msg.style.color = '#22c55e';
        emailInput.value = '';
      } else {
        msg.textContent = result.data.error || 'Error al suscribirse.';
        msg.style.color = '#FF9A2E';
      }
    })
    .catch(function() {
      msg.classList.remove('hidden');
      msg.textContent = 'Error de conexión. Intentá de nuevo.';
      msg.style.color = '#ef4444';
    })
    .finally(function() {
      btn.disabled = false;
      btn.textContent = 'Suscribirme';
      // Reset Turnstile for next attempt
      if (window.turnstile) {
        var widget = form.querySelector('.cf-turnstile');
        if (widget) window.turnstile.reset(widget);
      }
    });
  });
</script>
